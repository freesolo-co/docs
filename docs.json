				"items": [
					{
						"label": "Careers",
						"href": "https://freesolo.co/contact"
					},
					{
						"label": "Privacy Policy",
						"href": "https://freesolo.co/privacy"
					},
					{
						"label": "Terms",
						"href": "https://freesolo.co/terms"
					}
				]
			},
			{
				"header": "Contact",
				"items": [
					{
						"label": "Sales",
						"href": "https://freesolo.co/contact"
					},
					{
						"label": "Support",
						"href": "https://freesolo.co/contact"
					}
				]
			}
		]
