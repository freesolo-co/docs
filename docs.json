{
	"$schema": "https://mintlify.com/docs.json",
	"theme": "mint",
	"name": "Freesolo Docs",
	"description": "Train, deploy, and chat with custom LoRA models on managed infrastructure.",
	"favicon": "/favicon.svg",
	"colors": {
		"primary": "#5f72ff",
		"light": "#8b98ff",
		"dark": "#1b1b4b"
	},
	"logo": {
		"light": "/logo/freesolo-wordmark-light.svg",
		"dark": "/logo/freesolo-wordmark-dark.svg",
		"href": "https://freesolo.co"
	},
	"fonts": {
		"family": "Figtree"
	},
	"navigation": {
		"groups": [
			{
				"group": "Get started",
				"pages": ["index", "quickstart", "platform"]
			},
			{
				"group": "Flash",
				"pages": [
					{
						"group": "Core concepts",
						"pages": ["how-flash-works", "environment-model", "directory-structure"]
					},
					"guides/training",
					"guides/environments",
					"guides/datasets",
					"guides/deploy-and-chat"
				]
			},
			{
				"group": "Reference",
				"pages": ["reference/models", "reference/cli", "reference/configuration", "reference/cost-model", "reference/troubleshooting"]
			}
		]
	},
	"redirects": [
		{
			"source": "/conventions",
			"destination": "/guides/training"
		},
		{
			"source": "/guides/conventions",
			"destination": "/guides/training"
		}
	],
	"navbar": {
		"primary": {
			"type": "button",
			"label": "Create API Key",
			"href": "https://freesolo.co/platform"
		}
	},
	"footer": {
		"socials": {
			"linkedin": "https://www.linkedin.com/company/freesolo-co",
			"github": "https://github.com/freesolo-co",
			"x": "https://twitter.com/freesolo"
		},
		"links": [
			{
